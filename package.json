{
  "name": "markdown-blog",
  "version": "1.0.0",
  "description": "A static site that converts markdown into blog pages",
  "homepage": "https://github.com/codedonkeyuk/markdown-blog#readme",
  "bugs": {
    "url": "https://github.com/codedonkeyuk/markdown-blog/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codedonkeyuk/markdown-blog.git"
  },
  "license": "UNLICENCED",
  "private": "true",
  "author": "Leigh G",
  "type": "module",
  "bin": {
    "build-blog": "./dist/blog-generation/app.js",
    "create-post": "./dist/create-post/app.js",
    "html-validate-dev": "./dist/html-validate/html-validate-dev.js",
    "html-validate-prod": "./dist/html-validate/html-validate-prod.js",
    "serve-dev": "./dist/serve-site/serve-dev.js",
    "serve-prod": "./dist/serve-site/serve-prod.js"
  },
  "scripts": {
    "validate": "node src/html-validate/html-validate-dev.ts && prettier . --check && tsc --noEmit",
    "clean": "prettier . --write",
    "build": "tsc -p tsconfig.build.json",
    "test": "node --test --experimental-strip-types --experimental-test-module-mocks \"**/*.test.ts\"",
    "coverage": "node --experimental-strip-types --experimental-test-module-mocks --test --experimental-test-coverage \"**/*.test.ts\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/clean-css": "^4.2.11",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/live-server": "^1.2.3",
    "@types/node": "^26.1.1",
    "html-minifier-terser": "^7.2.0",
    "husky": "^9.1.7",
    "live-server": "^1.2.2",
    "prettier": "3.9.5",
    "terser": "^5.49.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "cspell": "^10.0.1",
    "html-validate": "^11.5.5",
    "lightningcss": "^1.32.0",
    "shiki": "^4.3.1"
  },
  "overrides": {
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "uuid": "^11.1.1"
  },
  "allowScripts": {
    "fsevents@1.2.13": true
  }
}
